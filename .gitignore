#--------------------------------------------------------------------
# CodeIgniter 4 .gitignore
# Dépôt: https://github.com/codeigniter4/CodeIgniter4
#--------------------------------------------------------------------

# Fichiers/dossiers d'environnement
.env
.env.*.php
.env.php

# Dossiers générés
writable/cache/*
writable/database/*.db
writable/database/*.sqlite
writable/logs/*
writable/session/*
writable/uploads/*
!writable/cache/.gitkeep
!writable/logs/.gitkeep
!writable/session/.gitkeep

# IDE
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store

# Dépendances Composer
vendor/
composer.lock

# Fichiers système
.DS_Store
Thumbs.db

# Tests
tests/_support/_generated/*

# Dossier public (uploads utilisateur)
public/uploads/*
!public/uploads/.gitkeep

# Modules personnalisés (optionnel)
app/Modules/*/

# PHPUnit
.phpunit.result.cache

# Dossier temporaire
tmp/
temp/
